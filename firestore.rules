// #16 — Firestore Security Rules
// 部署方式：firebase deploy --only firestore:rules
// 或在 Firebase Console > Firestore > 規則 貼上此內容

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ────────────────────────────────────────────────────────────

    // 判斷目前請求是否為已登入的 Firebase 用戶（含匿名）
    function isSignedIn() {
      return request.auth != null;
    }

    // 判斷日期字串格式是否合法 YYYY-MM-DD
    function isValidDateFormat(date) {
      return date.matches('\\d{4}-\\d{2}-\\d{2}');
    }

    // 判斷日期是否在活動範圍內（2026-06-01 ~ 2026-06-30）
    function isValidChallengeDate(date) {
      return isValidDateFormat(date)
        && date >= '2026-06-01'
        && date <= '2026-06-30';
    }

    // ── users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // 任何已登入用戶皆可建立自己的帳號
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['name', 'authUid', 'pin', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 20
        && request.resource.data.pin is string
        && request.resource.data.pin.matches('\\d{4}')
        && request.resource.data.authUid == request.auth.uid;

      // 只有帳號擁有者（authUid 與 Firebase uid 相符）可以讀取和更新
      allow read: if isSignedIn()
        && (resource.data.authUid == request.auth.uid);

      allow update: if isSignedIn()
        && (resource.data.authUid == request.auth.uid
            || request.resource.data.authUid == request.auth.uid)
        // 只允許更新 authUid 欄位（換裝置補救），不允許修改 name、pin
        && request.resource.data.name == resource.data.name
        && request.resource.data.pin == resource.data.pin;

      allow delete: if false; // 不允許刪除
    }

    // 允許按名字+PIN 查詢（recoverByNameAndPin 用）
    // 注意：Firestore 無法在規則中限制 where 查詢，
    // 需靠 composite index 和客戶端驗證雙重防護。
    match /users/{userId} {
      allow list: if isSignedIn();
    }

    // ── checkins ──────────────────────────────────────────────────────────
    match /checkins/{checkinId} {
      // 只有帳號擁有者可以讀取自己的打卡記錄
      allow read: if isSignedIn()
        && resource.data.userId != null
        && exists(/databases/$(database)/documents/users/$(resource.data.userId))
        && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.authUid == request.auth.uid;

      // 允許已登入用戶建立/更新打卡記錄，並驗證：
      // 1. 文件 ID 格式為 {userId}_{date}
      // 2. 日期在活動範圍內
      // 3. userId 欄位對應到自己的帳號
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasAll(['userId', 'date', 'completed'])
        && request.resource.data.completed is bool
        && isValidChallengeDate(request.resource.data.date)
        && checkinId == request.resource.data.userId + '_' + request.resource.data.date
        && exists(/databases/$(database)/documents/users/$(request.resource.data.userId))
        && get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data.authUid == request.auth.uid;

      allow delete: if false;
    }
  }
}
