rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    // 只有 authUid 符合的使用者才能讀取或更新自己的文件。
    // 建立時驗證 authUid 必須等於呼叫者的 uid。
    match /users/{userId} {
      allow read: if request.auth != null
                  && resource.data.authUid == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.authUid == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 20;

      allow update: if request.auth != null
                    && resource.data.authUid == request.auth.uid;

      allow delete: if false;
    }

    // ── CheckIns ─────────────────────────────────────────────────────────────
    // doc id 格式：{userId}_{date}
    // 只允許寫入 userId 對應到自己帳號的 checkin。
    match /checkins/{checkinId} {
      // 讀取：只能查自己的 userId
      allow read: if request.auth != null
                  && isOwnerOfUserId(resource.data.userId);

      // 建立 / 更新：checkin 的 userId 必須屬於呼叫者，且 date 格式合法
      allow create, update: if request.auth != null
                             && isOwnerOfUserId(request.resource.data.userId)
                             && request.resource.data.date is string
                             && request.resource.data.date.matches('\\d{4}-\\d{2}-\\d{2}')
                             && request.resource.data.completed is bool;

      allow delete: if false;
    }

    // ── Helper ───────────────────────────────────────────────────────────────
    // 確認某個 userId 文件的 authUid 等於目前登入者的 uid
    function isOwnerOfUserId(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return userDoc.data.authUid == request.auth.uid;
    }
  }
}
